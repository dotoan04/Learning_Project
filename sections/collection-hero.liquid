<section
  class="collection-hero"
  style="
    --padding-top: {{ section.settings.padding_top }}px;
    --padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="collection-hero__container">
    <!-- Column1: Image Slider -->
    <div class="collection-hero__slider">
      <div class="collection-hero__slides" data-slides>
        {% for block in section.blocks %}
          {% if block.type == 'slide' %}
            <div class="collection-hero__slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 1200 }}"
                  alt="{{ block.settings.image.alt | default: section.settings.heading | escape }}"
                  class="collection-hero__slide-image"
                  loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  width="800"
                  height="600"
                >
              {% else %}
                <div class="collection-hero__slide-placeholder">
                  {{ 'lifestyle-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.blocks.size > 1 %}
        <div class="collection-hero__slider-nav">
          {% for block in section.blocks %}
            {% if block.type == 'slide' %}
              <button
                type="button"
                class="collection-hero__slider-dot{% if forloop.first %} is-active{% endif %}"
                data-slide-index="{{ forloop.index0 }}"
                aria-label="{{ 'accessibility.slide' | t: number: forloop.index }}"
              ></button>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- Column2: Two images (20% each) + content -->
    <div class="collection-hero__side">
      <div class="collection-hero__images">
        <div class="collection-hero__image">
          {% if section.settings.side_image_1 != blank %}
            <img
              src="{{ section.settings.side_image_1 | image_url: width: 600 }}"
              alt="{{ section.settings.heading | escape }}"
              class="collection-hero__img"
              loading="lazy"
              width="400"
              height="300"
            >
          {% else %}
            <div class="collection-hero__placeholder">
              {{ 'lifestyle-2' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>

        <div class="collection-hero__image">
          {% if section.settings.side_image_2 != blank %}
            <img
              src="{{ section.settings.side_image_2 | image_url: width: 600 }}"
              alt="{{ section.settings.heading | escape }}"
              class="collection-hero__img"
              loading="lazy"
              width="400"
              height="300"
            >
          {% else %}
            <div class="collection-hero__placeholder">
              {{ 'lifestyle-3' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="collection-hero__content">
        {% if section.settings.heading != blank %}
          <h1 class="collection-hero__heading">{{ section.settings.heading | escape }}</h1>
        {% endif %}

        {% if section.settings.text != blank %}
          <p class="collection-hero__text">{{ section.settings.text | escape }}</p>
        {% endif %}

        {% if section.settings.button_label != blank %}
          {% render 'button',
            label: section.settings.button_label,
            url: section.settings.button_link,
            style: section.settings.button_style
          %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .collection-hero {
    padding-top: var(--padding-top);
    padding-bottom: var(--padding-bottom);
  }

  .collection-hero__container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 3vw, 2rem);
  }

  /* Slider Column */
  .collection-hero__slider {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
  }

  .collection-hero__slides {
    position: relative;
    aspect-ratio: 4/3;
  }

  .collection-hero__slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .collection-hero__slide.is-active {
    opacity: 1;
  }

  .collection-hero__slide-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .collection-hero__slide-placeholder {
    width: 100%;
    height: 100%;
    background-color: #f0f0f0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .collection-hero__slide-placeholder svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .collection-hero__slider-nav {
    position: absolute;
    bottom: 1rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0.5rem;
  }

  .collection-hero__slider-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    background-color: rgba(255, 255, 255, 0.5);
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .collection-hero__slider-dot.is-active {
    background-color: #ffffff;
  }

  /* Side Column */
  .collection-hero__side {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-radius: 12px;
    overflow: hidden;
    min-height: 100%;
  }

  .collection-hero__images {
    display: grid;
    grid-template-rows: minmax(6rem, 20%) minmax(6rem, 20%);
    gap: 1rem;
    min-height: 0;
  }

  .collection-hero__image {
    min-height: 0;
    border-radius: 8px;
    overflow: hidden;
  }

  .collection-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .collection-hero__image:hover .collection-hero__img {
    transform: scale(1.05);
  }

  .collection-hero__placeholder {
    width: 100%;
    height: 100%;
    background-color: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .collection-hero__placeholder svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .collection-hero__content {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
    flex: 1;
    justify-content: center;
    padding: 0.25rem 0.25rem 0.5rem;
    max-width: none;
  }

  .collection-hero__heading {
    margin: 0;
    font-size: clamp(1.9rem, 4vw, 3.2rem);
    line-height: 1.02;
    letter-spacing: 0.01em;
    font-family: the-seasons, sans-serif;
    font-weight: 400;
    color: #1f1f1f;
  }

  .collection-hero__text {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: #4a4a4a;
  }

  /* Tablet */
  @media (max-width: 989px) {
    .collection-hero__container {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .collection-hero__slides {
      aspect-ratio: 16/9;
    }

    .collection-hero__images {
      grid-template-rows: minmax(5.5rem, 20%) minmax(5.5rem, 20%);
    }

    .collection-hero__content {
      text-align: center;
      align-items: center;
    }
  }

  /* Mobile */
  @media (max-width: 749px) {
    .collection-hero__container {
      gap: 1rem;
    }

    .collection-hero__slides {
      aspect-ratio: 4/3;
    }

    .collection-hero__images {
      grid-template-rows: minmax(4.5rem, 20%) minmax(4.5rem, 20%);
      gap: 0.5rem;
    }

    .collection-hero__image {
      border-radius: 6px;
    }

    .collection-hero__content {
      gap: 0.75rem;
      padding: 0.25rem 0.1rem 0.35rem;
    }

    .collection-hero__heading {
      font-size: clamp(1.5rem, 6vw, 2rem);
    }

    .collection-hero__text {
      font-size: 0.9rem;
    }
  }
{% endstylesheet %}

{% javascript %}
  const sliderContainer = document.querySelector('.collection-hero__slider');
  if (sliderContainer) {
    const slides = sliderContainer.querySelectorAll('.collection-hero__slide');
    const dots = sliderContainer.querySelectorAll('.collection-hero__slider-dot');
    let currentSlide = 0;
    let autoPlayInterval;

    function showSlide(index) {
      slides.forEach((slide, i) => {
        slide.classList.toggle('is-active', i === index);
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === index);
      });
      currentSlide = index;
    }

    function nextSlide() {
      const next = (currentSlide + 1) % slides.length;
      showSlide(next);
    }

    function startAutoPlay() {
      autoPlayInterval = setInterval(nextSlide, 4000);
    }

    function stopAutoPlay() {
      clearInterval(autoPlayInterval);
    }

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        stopAutoPlay();
        showSlide(index);
        startAutoPlay();
      });
    });

    if (slides.length > 1) {
      startAutoPlay();
    }
  }
{% endjavascript %}

{% schema %}
{
  "name": "Collection hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Discover our latest collection of premium products designed for modern living."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark", "label": "Dark" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "dark"
    },
    {
      "type": "image_picker",
      "id": "side_image_1",
      "label": "Side image 1"
    },
    {
      "type": "image_picker",
      "id": "side_image_2",
      "label": "Side image 2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection hero",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
