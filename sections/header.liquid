<header>
  <h2 class="header__title">
    <a class="header__brand" href="{{ routes.root_url }}">{{ shop.name }}</a>
  </h2>

  <div class="header__menu">
    {% for link in section.settings.menu.links %}
      <a class="header__menu-link{% if link.current %} is-active{% endif %}" href="{{ link.url }}">{{ link.title }}</a>
    {% endfor %}
  </div>

  <div class="header__icons">
    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    <a class="header__cart" href="{{ routes.cart_url }}">
      {% if cart.item_count > 0 %}
        <sup>{{ cart.item_count }}</sup>
      {% endif %}

      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

{% stylesheet %}
  header {
    position: sticky;
    top: 0;
    z-index: 20;
    min-height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-inline: clamp(1rem, 3vw, 2rem);
    background: color-mix(in srgb, var(--color-background) 84%, transparent);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid color-mix(in srgb, var(--color-foreground) 12%, transparent);
  }
  header .header__title {
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    line-height: 1;
  }
  header .header__brand {
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  header a {
    position: relative;
    text-decoration: none;
    color: var(--color-foreground);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 160ms ease, transform 160ms ease;
  }
  header a:hover {
    opacity: 0.8;
  }
  header a sup {
    position: absolute;
    left: 100%;
    top: 0;
    overflow: hidden;
    max-width: var(--page-margin);
    font-size: 0.75rem;
    font-weight: 700;
    transform: translate(-0.25rem, -0.15rem);
  }
  header svg {
    width: 1.75rem;
    height: 1.75rem;
  }
  header .header__menu,
  header .header__icons {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  header .header__menu-link {
    font-size: 0.95rem;
    padding-block: 0.4rem;
  }
  header .header__menu-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.1rem;
    width: 100%;
    height: 2px;
    background: currentcolor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 180ms ease;
  }
  header .header__menu-link:hover::after,
  header .header__menu-link.is-active::after {
    transform: scaleX(1);
  }
  @media (max-width: 749px) {
    header {
      flex-wrap: wrap;
      justify-content: center;
      padding-block: 0.75rem;
    }
    header .header__title {
      order: 1;
      width: 100%;
      text-align: center;
    }
    header .header__menu {
      order: 2;
      justify-content: center;
      flex-wrap: wrap;
    }
    header .header__icons {
      order: 3;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
