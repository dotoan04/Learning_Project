<header class="site-header full-width">
  {% if section.settings.announcement_text != blank %}
    <p class="site-header__announcement">{{ section.settings.announcement_text }}</p>
  {% endif %}

  <div class="site-header__main">
    <nav class="site-header__menu" aria-label="Primary">
      {% for link in section.settings.menu.links %}
        <a class="site-header__menu-link{% if link.current %} is-active{% endif %}" href="{{ link.url }}">
          {{ link.title }}
          {% if section.settings.show_menu_plus %}
            <span aria-hidden="true" class="site-header__menu-plus">+</span>
          {% endif %}
        </a>
      {% endfor %}
    </nav>

    <h2 class="site-header__brand-wrap">
      <a class="site-header__brand" href="{{ routes.root_url }}">
        {% if section.settings.logo_image != blank %}
          {{ section.settings.logo_image | image_url: width: section.settings.logo_width | image_tag: widths: '160,220,320,440', class: 'site-header__logo-image', alt: shop.name }}
        {% else %}
          {{ shop.name }}
        {% endif %}
      </a>
    </h2>

    <div class="site-header__icons">
      {% if section.settings.show_search %}
        <a href="{{ routes.search_url }}" aria-label="Search">
          <svg viewBox="0 0 24 24" role="presentation" focusable="false">
            <circle cx="11" cy="11" r="7" fill="none" stroke="currentColor" stroke-width="1.8"></circle>
            <line x1="16.7" y1="16.7" x2="21" y2="21" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></line>
          </svg>
        </a>
      {% endif %}

      {% if section.settings.show_account and shop.customer_accounts_enabled %}
        <shopify-account menu="{{ section.settings.customer_account_menu }}">
          {{ 'icon-account.svg' | inline_asset_content }}
        </shopify-account>
      {% endif %}

      <a class="site-header__cart" href="{{ routes.cart_url }}" aria-label="Cart">
        {% if cart.item_count > 0 %}
          <sup>{{ cart.item_count }}</sup>
        {% endif %}
        {{ 'icon-cart.svg' | inline_asset_content }}
      </a>
    </div>
  </div>
</header>

{% stylesheet %}
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: var(--color-background);
    border-bottom: 1px solid color-mix(in srgb, var(--color-foreground) 12%, transparent);
  }

  .site-header__announcement {
    text-align: center;
    padding: 0.7rem 1rem;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border-bottom: 1px solid color-mix(in srgb, var(--color-foreground) 8%, transparent);
    color: color-mix(in srgb, var(--color-foreground) 88%, transparent);
  }

  .site-header__main {
    min-height: 5.6rem;
    display: grid;
    align-items: center;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    gap: 1rem;
    padding-inline: clamp(1rem, 2.8vw, 3rem);
  }

  .site-header__menu {
    display: flex;
    align-items: center;
    gap: clamp(0.8rem, 1.6vw, 1.8rem);
    min-width: 0;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .site-header__menu::-webkit-scrollbar {
    display: none;
  }

  .site-header__menu-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    white-space: nowrap;
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 1.05rem;
    line-height: 1;
    position: relative;
    opacity: 0.92;
    transition: opacity 180ms ease;
  }

  .site-header__menu-link:hover,
  .site-header__menu-link.is-active {
    opacity: 1;
  }

  .site-header__menu-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -0.45rem;
    width: 100%;
    height: 1px;
    background: currentcolor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 180ms ease;
  }

  .site-header__menu-link:hover::after,
  .site-header__menu-link.is-active::after {
    transform: scaleX(1);
  }

  .site-header__menu-plus {
    font-size: 1rem;
    line-height: 1;
  }

  .site-header__brand-wrap {
    margin: 0;
    line-height: 1;
    text-align: center;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground);
    text-decoration: none;
    font-size: clamp(1.2rem, 1.8vw, 1.6rem);
    font-weight: 500;
  }

  .site-header__logo-image {
    width: auto;
    max-height: 4rem;
  }

  .site-header__icons {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(0.9rem, 1.6vw, 1.4rem);
  }

  .site-header__icons a,
  .site-header__icons shopify-account {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--color-foreground);
  }

  .site-header__icons svg {
    width: 1.85rem;
    height: 1.85rem;
  }

  .site-header__cart {
    position: relative;
  }

  .site-header__cart sup {
    position: absolute;
    top: -0.2rem;
    right: -0.45rem;
    min-width: 1.05rem;
    height: 1.05rem;
    border-radius: 999px;
    font-size: 0.68rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-foreground);
    color: var(--color-background);
  }

  @media (max-width: 990px) {
    .site-header__main {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        'brand icons'
        'menu menu';
      row-gap: 0.85rem;
      padding-block: 0.85rem;
    }

    .site-header__brand-wrap {
      grid-area: brand;
      text-align: left;
    }

    .site-header__icons {
      grid-area: icons;
    }

    .site-header__menu {
      grid-area: menu;
      justify-content: flex-start;
      padding-bottom: 0.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "AUSTRALIAN NATURAL BEAUTY & SKINCARE, ROOTED IN RITUAL"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "checkbox",
      "id": "show_menu_plus",
      "label": "Show + on menu links",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 80,
      "max": 320,
      "step": 10,
      "unit": "px",
      "default": 210
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search icon",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account icon",
      "default": false
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
