<section
  class="hero-banner full-width"
  style="
    --hero-overlay-alpha: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --hero-height-desktop: {{ section.settings.height_desktop }}px;
    --hero-height-mobile: {{ section.settings.height_mobile }}px;
  "
>
  <div class="hero-banner__media">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          widths: '750,1100,1500,1800,2200,2400',
          sizes: '100vw',
          class: 'hero-banner__image',
          alt: section.settings.heading
      }}
    {% else %}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-banner__placeholder' }}
    {% endif %}
  </div>

  <div class="hero-banner__overlay"></div>

  <div class="hero-banner__content">
    {% if section.settings.heading != blank %}
      <h1 class="hero-banner__heading">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.button_label != blank %}
      {% render 'button',
        label: section.settings.button_label,
        url: section.settings.button_link,
        style: section.settings.button_style
      %}
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .hero-banner {
    position: relative;
    min-height: var(--hero-height-desktop);
    isolation: isolate;
    display: grid;
    place-items: center;
  }

  .hero-banner__media,
  .hero-banner__overlay,
  .hero-banner__content {
    grid-area: 1 / 1;
    width: 100%;
    height: 100%;
  }

  .hero-banner__image,
  .hero-banner__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-banner__overlay {
    background: linear-gradient(
      to bottom,
      color-mix(in srgb, #000000 calc(var(--hero-overlay-alpha) * 100%), transparent) 10%,
      color-mix(in srgb, #000000 calc((var(--hero-overlay-alpha) + 0.15) * 100%), transparent) 100%
    );
  }

  .hero-banner__content {
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    text-align: center;
    gap: 1.25rem;
    color: #ffffff;
    padding: clamp(1.2rem, 2.4vw, 2rem);
    padding-bottom: clamp(2rem, 6vw, 4rem);
  }

  .hero-banner__heading {
    margin: 0;
    max-width: 18ch;
    font-size: clamp(1.9rem, 4.8vw, 4.1rem);
    line-height: 1.02;
    letter-spacing: 0.01em;
    text-wrap: balance;
  }

  @media (max-width: 749px) {
    .hero-banner {
      min-height: var(--hero-height-mobile);
    }

    .hero-banner__heading {
      font-size: clamp(1.6rem, 9vw, 2.4rem);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "FROM GARDEN TO GLOW"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark", "label": "Dark" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "light"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 25
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Desktop height",
      "min": 420,
      "max": 980,
      "step": 20,
      "unit": "px",
      "default": 760
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Mobile height",
      "min": 320,
      "max": 820,
      "step": 20,
      "unit": "px",
      "default": 520
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
