<div
  class="brand-carousel"
  style="
    --padding: {{ section.settings.padding }}px;
    --gap: {{ section.settings.gap }}px;
    --logo-width: {{ section.settings.logo_width }}px;
    --scroll-speed: {{ section.settings.scroll_speed }}s;
  "
>
  {% if section.settings.title != blank %}
    <h2 class="brand-carousel__title">{{ section.settings.title }}</h2>
  {% endif %}

  <div class="brand-carousel__wrapper">
    <div class="brand-carousel__track{% if section.settings.enable_auto_scroll %} brand-carousel__track--auto-scroll{% endif %}">
      {% for block in section.blocks %}
        <div class="brand-carousel__item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a href="{{ block.settings.link }}" class="brand-carousel__link">
          {% endif %}

          {% if block.settings.image != blank %}
            <div class="brand-carousel__image">
              {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy' }}
            </div>
          {% else %}
            <div class="brand-carousel__placeholder">
              {{ 'logo' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}

      {% if section.settings.enable_auto_scroll and section.blocks.size > 0 %}
        {% comment %} Duplicate items for infinite scroll effect {% endcomment %}
        {% for block in section.blocks %}
          <div class="brand-carousel__item" aria-hidden="true">
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="brand-carousel__link" tabindex="-1">
            {% endif %}

            {% if block.settings.image != blank %}
              <div class="brand-carousel__image">
                {{ block.settings.image | image_url: width: 400 | image_tag: loading: 'lazy' }}
              </div>
            {% else %}
              <div class="brand-carousel__placeholder">
                {{ 'logo' | placeholder_svg_tag }}
              </div>
            {% endif %}

            {% if block.settings.link != blank %}
              </a>
            {% endif %}
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

{% stylesheet %}
  .brand-carousel {
    width: 100%;
    padding: var(--padding) 0;
    overflow: hidden;
  }

  .brand-carousel__title {
    text-align: center;
    margin: 0 0 2rem;
    font-size: clamp(1.9rem, 4vw, 3.2rem);
    line-height: 1.02;
    letter-spacing: 0.01em;
    text-wrap: balance;
    font-family: the-seasons, sans-serif;
    font-weight: 400;
    color: #1f1f1f;
  }

  .brand-carousel__wrapper {
    width: 100%;
    overflow: hidden;
  }

  .brand-carousel__track {
    display: flex;
    gap: var(--gap);
    padding: 0 var(--padding);
  }

  .brand-carousel__track--auto-scroll {
    animation: scroll var(--scroll-speed) linear infinite;
  }

  .brand-carousel__track--auto-scroll:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .brand-carousel__item {
    flex-shrink: 0;
    width: var(--logo-width);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-carousel__link {
    display: block;
    width: 100%;
    height: 100%;
    transition: opacity 0.3s ease;
  }

  .brand-carousel__link:hover {
    opacity: 0.7;
  }

  .brand-carousel__image {
    width: 100%;
    height: auto;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-carousel__image img {
    max-width: 100%;
    height: auto;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.6;
    transition: filter 0.3s ease, opacity 0.3s ease;
  }

  .brand-carousel__item:hover .brand-carousel__image img {
    filter: grayscale(0%);
    opacity: 1;
  }

  .brand-carousel__placeholder {
    width: 100%;
    height: 80px;
    background-color: rgba(0, 0, 0, 0.05);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-carousel__placeholder svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }
{% endstylesheet %}

{% javascript %}
  // Optional: Add drag-to-scroll functionality
  const carousels = document.querySelectorAll('.brand-carousel__track:not(.brand-carousel__track--auto-scroll)');

  carousels.forEach(track => {
    let isDown = false;
    let startX;
    let scrollLeft;

    const wrapper = track.parentElement;

    wrapper.addEventListener('mousedown', (e) => {
      isDown = true;
      wrapper.style.cursor = 'grabbing';
      startX = e.pageX - wrapper.offsetLeft;
      scrollLeft = wrapper.scrollLeft;
    });

    wrapper.addEventListener('mouseleave', () => {
      isDown = false;
      wrapper.style.cursor = 'grab';
    });

    wrapper.addEventListener('mouseup', () => {
      isDown = false;
      wrapper.style.cursor = 'grab';
    });

    wrapper.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - wrapper.offsetLeft;
      const walk = (x - startX) * 2;
      wrapper.scrollLeft = scrollLeft - walk;
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "t:general.brand_carousel",
  "tag": "section",
  "class": "brand-carousel-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.title",
      "default": "Our brands"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 80,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "t:labels.logo_width",
      "default": 150
    },
    {
      "type": "range",
      "id": "gap",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "t:labels.gap",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "t:labels.padding",
      "default": 40
    },
    {
      "type": "checkbox",
      "id": "enable_auto_scroll",
      "label": "t:labels.enable_auto_scroll",
      "default": true
    },
    {
      "type": "range",
      "id": "scroll_speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "t:labels.scroll_speed",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "brand",
      "name": "t:general.brand",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.logo"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:labels.link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.brand_carousel",
      "blocks": [
        {
          "type": "brand"
        },
        {
          "type": "brand"
        },
        {
          "type": "brand"
        },
        {
          "type": "brand"
        },
        {
          "type": "brand"
        }
      ]
    }
  ]
}
{% endschema %}
