<section class="introduce-shop full-width">
  <div class="introduce-shop__container">
    <div class="introduce-shop__content">
      {% if section.settings.heading != blank %}
        <h2 class="introduce-shop__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <p class="introduce-shop__text">{{ section.settings.text }}</p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        {% render 'button',
          label: section.settings.button_label,
          url: section.settings.button_link,
          style: section.settings.button_style
        %}
      {% endif %}
    </div>

    <div class="introduce-shop__images">
      {% if section.settings.image_1 != blank %}
        <div class="introduce-shop__image introduce-shop__image--1">
          {{
            section.settings.image_1
            | image_url: width: 800
            | image_tag:
              widths: '400,600,800',
              sizes: '(min-width: 750px) 33vw, 50vw',
              class: 'introduce-shop__img',
              alt: section.settings.heading
          }}
        </div>
      {% else %}
        <div class="introduce-shop__image introduce-shop__image--1">
          {{ 'image' | placeholder_svg_tag: 'introduce-shop__placeholder' }}
        </div>
      {% endif %}

      {% if section.settings.image_2 != blank %}
        <div class="introduce-shop__image introduce-shop__image--2">
          {{
            section.settings.image_2
            | image_url: width: 800
            | image_tag:
              widths: '400,600,800',
              sizes: '(min-width: 750px) 33vw, 50vw',
              class: 'introduce-shop__img',
              alt: section.settings.heading
          }}
        </div>
      {% else %}
        <div class="introduce-shop__image introduce-shop__image--2">
          {{ 'image' | placeholder_svg_tag: 'introduce-shop__placeholder' }}
        </div>
      {% endif %}

      {% if section.settings.image_3 != blank %}
        <div class="introduce-shop__image introduce-shop__image--3">
          {{
            section.settings.image_3
            | image_url: width: 800
            | image_tag:
              widths: '400,600,800',
              sizes: '(min-width: 750px) 33vw, 50vw',
              class: 'introduce-shop__img',
              alt: section.settings.heading
          }}
        </div>
      {% else %}
        <div class="introduce-shop__image introduce-shop__image--3">
          {{ 'image' | placeholder_svg_tag: 'introduce-shop__placeholder' }}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .introduce-shop {
    padding: clamp(2rem, 5vw, 4rem) 0;
  }

  .introduce-shop__container {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 64px;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 3vw, 2rem);
  }

  .introduce-shop__content {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    max-width: 400px;
  }

  .introduce-shop__heading {
    margin: 0;
    font-size: clamp(1.9rem, 4vw, 3.2rem);
    line-height: 1.02;
    letter-spacing: 0.01em;
    text-wrap: balance;
    font-family: the-seasons, sans-serif;
    font-weight: 400;
    color: #1f1f1f;
  }

  .introduce-shop__text {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
    color: #4a4a4a;
  }

  .introduce-shop__images {
    flex: 1;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .introduce-shop__image {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    aspect-ratio: 3/4;
  }

  .introduce-shop__image--1 {
    transform: translateY(20px);
  }

  .introduce-shop__image--2 {
    transform: translateY(-10px);
  }

  .introduce-shop__image--3 {
    transform: translateY(30px);
  }

  .introduce-shop__img,
  .introduce-shop__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .introduce-shop__image:hover .introduce-shop__img {
    transform: scale(1.05);
  }

  .introduce-shop__placeholder {
    background: #f5f5f5;
  }

  /* Tablet */
  @media (max-width: 989px) {
    .introduce-shop {
      padding: 2rem 0;
    }

    .introduce-shop__container {
      flex-direction: column-reverse;
      gap: 2rem;
    }

    .introduce-shop__content {
      max-width: 100%;
      text-align: center;
      align-items: center;
      padding: 0 1rem;
    }

    .introduce-shop__heading {
      font-size: clamp(1.5rem, 6vw, 2.5rem);
    }

    .introduce-shop__text {
      font-size: 0.95rem;
      line-height: 1.7;
    }

    .introduce-shop__images {
      width: 100%;
      gap: 0.75rem;
    }

    .introduce-shop__image--1,
    .introduce-shop__image--2,
    .introduce-shop__image--3 {
      transform: none;
    }

    .introduce-shop__image {
      aspect-ratio: 3/4;
      border-radius: 6px;
    }
  }

  /* Mobile */
  @media (max-width: 749px) {
    .introduce-shop {
      padding: 1.5rem 0;
    }

    .introduce-shop__container {
      gap: 1.5rem;
      padding: 0 1rem;
    }

    .introduce-shop__content {
      gap: 1rem;
      padding: 0;
    }

    .introduce-shop__heading {
      font-size: clamp(1.4rem, 7vw, 2rem);
      line-height: 1.1;
    }

    .introduce-shop__text {
      font-size: 0.9rem;
      line-height: 1.7;
      color: #5a5a5a;
    }

    .introduce-shop__images {
      grid-template-columns: repeat(3, 1fr);
      gap: 0.5rem;
      width: 100%;
    }

    .introduce-shop__image {
      aspect-ratio: 1/1;
      border-radius: 4px;
    }

    .introduce-shop__img,
    .introduce-shop__placeholder {
      transition: none;
    }

    .introduce-shop__image:hover .introduce-shop__img {
      transform: none;
    }
  }

  /* Small Mobile */
  @media (max-width: 479px) {
    .introduce-shop {
      padding: 1.25rem 0;
    }

    .introduce-shop__container {
      gap: 1.25rem;
      padding: 0 0.75rem;
    }

    .introduce-shop__content {
      gap: 0.75rem;
    }

    .introduce-shop__heading {
      font-size: 1.5rem;
    }

    .introduce-shop__text {
      font-size: 0.85rem;
    }

    .introduce-shop__images {
      gap: 0.375rem;
    }

    .introduce-shop__image {
      border-radius: 3px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Introduce shop",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Story"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Discover our carefully curated collection of products designed to bring beauty and joy to your everyday life."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "light", "label": "Light" },
        { "value": "dark", "label": "Dark" },
        { "value": "outline", "label": "Outline" }
      ],
      "default": "dark"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "Image 1"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "Image 2"
    },
    {
      "type": "image_picker",
      "id": "image_3",
      "label": "Image 3"
    }
  ],
  "presets": [
    {
      "name": "Introduce shop"
    }
  ]
}
{% endschema %}
