{% doc %}
  Renders a product card with image, rating, price, and add to bag button.

  @param {product} product - The product object to render
  @param {string} [class] - Optional extra CSS classes
  @param {boolean} [show_rating] - Whether to show star rating (default: true)
  @param {boolean} [show_button] - Whether to show add to bag button (default: true)

  @example
  {% render 'card-product', product: product %}
  {% render 'card-product', product: product, show_rating: false %}
{% enddoc %}

{% liquid
  assign show_rating = show_rating | default: true
  assign show_button = show_button | default: true
  assign current_variant = product.selected_or_first_available_variant
  assign rating_value = 0
  assign rating_count = 0

  if product.metafields.reviews.rating.value != blank
    assign rating_value = product.metafields.reviews.rating.value
  endif

  if product.metafields.reviews.rating_count.value != blank
    assign rating_count = product.metafields.reviews.rating_count.value
  elsif product.metafields.reviews.rating_count != blank
    assign rating_count = product.metafields.reviews.rating_count
  endif
%}

<div class="card-product {{ class }}" data-product-id="{{ product.id }}">
  <a href="{{ product.url }}" class="card-product__link">
    <div class="card-product__image-wrapper">
      {% if product.featured_image %}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          class="card-product__image"
          loading="lazy"
          width="600"
          height="600"
        >
        {% if product.images.size > 1 %}
          <img
            src="{{ product.images[1] | image_url: width: 600 }}"
            alt="{{ product.images[1].alt | default: product.title | escape }}"
            class="card-product__image card-product__image--hover"
            loading="lazy"
            width="600"
            height="600"
          >
        {% endif %}
      {% else %}
        <div class="card-product__placeholder">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}

      {% if product.compare_at_price > product.price %}
        <span class="card-product__badge card-product__badge--sale">
          {{ 'products.sale' | t }}
        </span>
      {% endif %}

      {% unless product.available %}
        <span class="card-product__badge card-product__badge--soldout">
          {{ 'products.sold_out' | t }}
        </span>
      {% endunless %}
    </div>

    <div class="card-product__content">
      <h3 class="card-product__title">{{ product.title }}</h3>

      {% if show_rating %}
        <div class="card-product__rating">
          {% render 'star_rating', rating: rating_value %}
          <span class="card-product__rating-count">({{ rating_count }})</span>
        </div>
      {% endif %}

      <div class="card-product__price">
        {% if current_variant.compare_at_price > current_variant.price %}
          <span class="card-product__price--compare">{{ current_variant.compare_at_price | money }}</span>
          <span class="card-product__price--sale">{{ current_variant.price | money }}</span>
        {% else %}
          <span class="card-product__price--regular">{{ current_variant.price | money }}</span>
        {% endif %}
      </div>
    </div>
  </a>

  {% if show_button and product.available %}
    <div class="card-product__action">
      {% render 'button',
        label: 'products.add_to_bag' | t,
        url: product.url,
        style: 'dark',
        class: 'card-product__button'
      %}
    </div>
  {% endif %}
</div>

{% stylesheet %}
  .card-product {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .card-product__link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .card-product__image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1/1;
    overflow: hidden;
    border-radius: 8px;
    background-color: #f8f8f8;
  }

  .card-product__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.3s ease;
  }

  .card-product__image--hover {
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
  }

  .card-product__image-wrapper:hover .card-product__image:not(.card-product__image--hover) {
    opacity: 0;
  }

  .card-product__image-wrapper:hover .card-product__image--hover {
    opacity: 1;
  }

  .card-product__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f0f0f0;
  }

  .card-product__placeholder svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .card-product__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 4px 10px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: 4px;
  }

  .card-product__badge--sale {
    background-color: #e74c3c;
    color: #ffffff;
  }

  .card-product__badge--soldout {
    background-color: #95a5a6;
    color: #ffffff;
  }

  .card-product__content {
    padding: 1rem 0;
  }

  .card-product__title {
    margin: 0 0 0.5rem;
    font-size: 1rem;
    font-weight: 500;
    color: #1f1f1f;
    line-height: 1.4;
  }

  .card-product__rating {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
  }

  .card-product__rating-count {
    font-size: 0.8rem;
    color: #888;
  }

  .card-product__price {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1rem;
  }

  .card-product__price--regular {
    font-weight: 600;
    color: #1f1f1f;
  }

  .card-product__price--compare {
    font-size: 0.9rem;
    color: #999;
    text-decoration: line-through;
  }

  .card-product__price--sale {
    font-weight: 600;
    color: #e74c3c;
  }

  .card-product__action {
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .card-product__button {
    width: 100%;
  }

  /* Mobile */
  @media (max-width: 749px) {
    .card-product__image-wrapper {
      border-radius: 6px;
    }

    .card-product__content {
      padding: 0.75rem 0;
    }

    .card-product__title {
      font-size: 0.9rem;
    }

    .card-product__price {
      font-size: 0.9rem;
    }

    .card-product__badge {
      top: 8px;
      left: 8px;
      padding: 3px 8px;
      font-size: 0.65rem;
    }
  }
{% endstylesheet %}
