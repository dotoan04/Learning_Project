{% doc %}
  Renders a star rating display.

  @param {number} [rating] - The rating value (0-5)
  @param {string} [class] - Optional extra CSS classes

  @example
  {% render 'star-rating', rating: 4.5 %}
{% enddoc %}

{% assign rating_value = rating | default: 0 | plus: 0 | at_most: 5 | at_least: 0 %}
{% assign full_stars = rating_value | floor %}

<div class="star-rating {{ class }}" aria-label="{{ 'products.rating_label' | t: rating: rating_value }}">
  <span class="star-rating__stars">
    {% for i in (1..5) %}
      {% assign compare_value = i %}
      {% if compare_value <= full_stars %}
        <svg class="star-rating__icon star-rating__icon--full" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
      {% else %}
        <svg class="star-rating__icon star-rating__icon--empty" viewBox="0 0 20 20" aria-hidden="true">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
      {% endif %}
    {% endfor %}
  </span>
</div>

{% stylesheet %}
  .star-rating {
    display: inline-flex;
    align-items: center;
  }

  .star-rating__stars {
    display: inline-flex;
    gap: 2px;
  }

  .star-rating__icon {
    width: 14px;
    height: 14px;
    fill: currentColor;
  }

  .star-rating__icon--full {
    color: #f1c40f;
  }

  .star-rating__icon--empty {
    color: #ddd;
  }
{% endstylesheet %}
